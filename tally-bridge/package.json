{
  "name": "tally-bridge",
  "version": "1.0.0",
  "description": "Desktop connector for Tally to Cloud Portal - Bridges local Tally software with cloud-based B2B invoice sync platform",
  "main": "main.js",
  "author": "Saksham Maheshwari",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "pack": "electron-builder --dir",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "express": "^4.18.0",
    "keytar": "^7.9.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "ws": "^8.15.0",
    "xml2js": "^0.6.0"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.saksham.tallybridge",
    "productName": "Tally Bridge",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*",
      "build/**/*",
      "!**/*.md",
      "!.git",
      "!dist"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  }
}
